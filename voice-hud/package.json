{
  "name": "dm-whisper-hud",
  "productName": "DM Whisper",
  "version": "0.1.5",
  "description": "DM Whisper \u2014 voice PTT + transparent scrying-gem HUD for the Roll20 DM assistant",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && electron .",
    "dev": "tsc -w",
    "test": "vitest run",
    "test:watch": "vitest",
    "ab:stt": "tsx scripts/ab-stt.ts",
    "eval:tools": "tsx scripts/eval-tools.ts",
    "eval:arc": "tsx scripts/eval-arc.ts",
    "record": "tsx scripts/record-clips.ts",
    "bundle:server": "npx --yes esbuild ../src/index-http.ts --bundle --platform=node --format=esm --outfile=../dist-server/dist/index-http.mjs --external:playwright --external:sharp --banner:js=\"import{createRequire}from'module';const require=createRequire(import.meta.url);\"",
    "dist:dir": "npm run build && npm run bundle:server && electron-builder --dir",
    "dist": "npm run build && npm run bundle:server && electron-builder"
  },
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "electron": "^33.4.11",
    "electron-builder": "26.15.3",
    "jsdom": "^29.1.1",
    "tsx": "^4.20.0",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2",
    "double-metaphone": "^1.0.5",
    "openai": "^4.77.0",
    "uiohook-napi": "^1.5.4"
  },
  "overrides": {
    "@noble/hashes": "^1.8.0"
  }
}
