{
  "name": "roll20-dm-mcp",
  "version": "1.0.0",
  "description": "MCP server for Roll20 DM automation + D&D Beyond combat sync",
  "main": "dist/index-combat.js",
  "scripts": {
    "start": "node dist/index-combat.js",
    "build": "tsc",
    "dev": "tsx watch src/index-combat.ts",
    "serve": "tsx src/index-http.ts",
    "serve:watch": "tsx watch src/index-http.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "eslint src/**/*.ts test/**/*.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2",
    "firebase": "^12.14.0",
    "playwright": "^1.60.0",
    "sharp": "^0.34.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "@types/sharp": "^0.31.1",
    "eslint": "^10.5.0",
    "tsx": "^4.22.3",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^3.2.4"
  }
}
