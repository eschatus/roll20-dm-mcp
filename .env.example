ROLL20_EMAIL=your@email.com
ROLL20_PASSWORD=yourpassword

DDB_EMAIL=your@email.com
DDB_PASSWORD=yourpassword

# Optional: single-campaign fallback if you don't use register_campaign / switch_campaign
# ROLL20_CAMPAIGN_ID=12345678
# DDB_CAMPAIGN_ID=12345678

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Path where Playwright stores browser sessions (cookies, localStorage)
# Treat this directory like a password vault — keep it outside any cloud-synced folder
BROWSER_USER_DATA_DIR=./data/browser-session
